# Copy this file to ".env" and fill in your keys. Never commit the real ".env".

# --- Which LLM "brain" to use: "openai" (default) or "anthropic" ---
AILEEN_LLM_PROVIDER=openai

# --- OpenAI (used as the default brain, and for speech-to-text) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Speech-to-text model (OpenAI). "whisper-1" is the broadly available default.
STT_MODEL=whisper-1

# --- Anthropic / Claude (optional alternative brain) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- ElevenLabs (voice / text-to-speech) ---
ELEVENLABS_API_KEY=
# Pick a voice id from your ElevenLabs account (Voices page).
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# --- Bot persona / behaviour ---
BOT_NAME=Aileen

# --- Audio (sample rates in Hz) ---
MIC_SAMPLE_RATE=16000
TTS_SAMPLE_RATE=24000

# --- Knowledge base location (folder of .md / .txt files) ---
KNOWLEDGE_DIR=data/knowledge
