# Copy this file to ".env" and fill in your keys. Never commit the real ".env".

# --- Which LLM "brain" to use: "openai" (default) or "anthropic" ---
AILEEN_LLM_PROVIDER=openai

# --- OpenAI (used as the default brain, and for speech-to-text) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Speech-to-text model (OpenAI). "whisper-1" is the broadly available default.
STT_MODEL=whisper-1

# --- Anthropic / Claude (optional alternative brain) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Voice engine: "openai" (default, reuses your OpenAI key) or "elevenlabs" ---
AILEEN_TTS_PROVIDER=openai

# OpenAI voice (used when AILEEN_TTS_PROVIDER=openai).
# Voices: nova/shimmer (female), alloy/echo/fable/onyx (male-ish). Models: tts-1, tts-1-hd.
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# --- ElevenLabs (used when AILEEN_TTS_PROVIDER=elevenlabs; requires a paid plan) ---
ELEVENLABS_API_KEY=
# Pick a voice id from your ElevenLabs account (Voices page).
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# --- Bot persona / behaviour ---
BOT_NAME=Aileen

# --- Audio (sample rates in Hz) ---
MIC_SAMPLE_RATE=16000
TTS_SAMPLE_RATE=24000

# Which microphone to record from. Leave blank to use the Windows default —
# but note that virtual mics (e.g. "Steam Streaming Microphone") are often the
# default and record silence. Set this to a device index or a name fragment.
# Run `aileen --list-mics` to see the choices. Example: MIC_DEVICE=C920
MIC_DEVICE=

# Speak a short random acknowledgement ("Sure.", "One moment.") at the start of
# each reply. It's pre-rendered so it plays instantly, covering synthesis
# latency and sounding more conversational. Set to "false" to disable.
AILEEN_SPEAK_FILLERS=true
# Optional: your own filler phrases, pipe-separated. Blank = built-in set.
# Example: AILEEN_FILLER_PHRASES=Sure.|Let me check.|One moment.
AILEEN_FILLER_PHRASES=

# --- Knowledge base location (folder of .md / .txt files) ---
KNOWLEDGE_DIR=data/knowledge

# --- Debug: per-reply latency log (start/end + time-to-first-audio) ---
# Each spoken reply appends a line here. Leave blank to disable.
AILEEN_TIMING_LOG=logs/aileen-timing.log
